#[Expected Approach]- Using Mathematical Formulae - O(1) Time and O(1) Space
# Python code to find sum of 
# squares of first n natural numbers.
def summation(n):
    return (n * (n + 1) * 
           (2 * n + 1)) / 6
    
# Driver Code

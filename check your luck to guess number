import random
num = random.randint(1,10)
tries = 0
while True:
    guess = int(input("please guess your number b/w 1-10 :-"))
    if num == guess:
        tries +=1
        print(f"your are right you guessed the number {tries} tries ")
        break
    elif num < guess:
        print("go to little lower ")
        tries +=1
    elif num > guess:
        tries+=1
        print("go to little higher")
    else: 
        tries +=1
        print("sorry you are wrong")


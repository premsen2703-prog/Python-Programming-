import math
#program to find the area of circle
radius = float(input("Enter the radius of the circle: "))
#Formula: area = pi * r^2
area = math.pi * (radius ** 2)
#Rounding the result to 2 decimal place for neatness
print(f"The result of the circle with radius {radius} is: {round(area, 2)} ")


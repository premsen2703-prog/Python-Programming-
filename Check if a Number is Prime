# program to Check if a Number is Prime or not
n = int(input("Enter a number: "))
isprime = True

if n <= 1:
    isprime = False
else:
    for i in range(2,n):
        if n % i == 0:
            isprime = False
    
if isprime == True:
    print("it's prime.")
else:
    print("it's not prime.")


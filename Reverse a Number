# Program for reverse a number
num = int(input("Enter a number: "))
reverse = 0
# for loop reverse a number
while(num > 0):
    last_digit = num % 10
    reverse = (reverse * 10) + last_digit
    num = num // 10 
print(f"Reverse of Given number is: {reverse}")

